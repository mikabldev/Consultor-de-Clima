# ============================================
# CONFIGURACIÓN DE CLIMA APP
# ============================================

# APIs públicas (sin autenticación requerida)
VITE_GEOCODING_API_URL=https://geocoding-api.open-meteo.com/v1/search
VITE_WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Configuración de seguridad
VITE_API_TIMEOUT=5000
VITE_MAX_CITIES_PER_SEARCH=10
VITE_CACHE_EXPIRATION_MS=3600000
VITE_MAX_SEARCH_HISTORY=10
VITE_RATE_LIMIT_REQUESTS=30
VITE_RATE_LIMIT_WINDOW_MS=60000

# Configuración de localStorage
VITE_ENABLE_CACHE=true
VITE_CACHE_PREFIX=weather_cache_
VITE_HISTORY_KEY=search_history

# Configuración de validación
VITE_MIN_CITY_NAME_LENGTH=2
VITE_MAX_CITY_NAME_LENGTH=100
VITE_REQUIRE_HTTPS_PRODUCTION=true
